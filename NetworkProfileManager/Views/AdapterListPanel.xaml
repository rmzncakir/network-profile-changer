<UserControl x:Class="NetworkProfileManager.Views.AdapterListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

  <DockPanel>
    <!-- Header -->
    <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBorder}">
      <DockPanel>
        <TextBlock Text="{DynamicResource Adapters.Header}" Style="{StaticResource HeaderText}"/>
        <ui:Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                   Appearance="Secondary" Padding="8,5"
                   Command="{Binding RefreshCommand}" ToolTip="{DynamicResource Common.Refresh}">
          <ui:SymbolIcon Symbol="ArrowSync20" FontSize="14"/>
        </ui:Button>
      </DockPanel>
    </Border>

    <!-- Adapter cards list -->
    <ListBox ItemsSource="{Binding Adapters}"
             SelectedItem="{Binding SelectedAdapter}"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             
             BorderThickness="0"
             Background="{DynamicResource BackgroundBrush}"
             
             Padding="6,4,20,4">

      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Padding"                    Value="0"/>
          <Setter Property="Margin"                     Value="5,3,15,3"/>
          <Setter Property="Background"                 Value="Transparent"/>
          <Setter Property="BorderThickness"            Value="0"/>
          <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <ContentPresenter/>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ListBox.ItemContainerStyle>

      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border x:Name="CardBorder"
                  Background="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,10"
                  Cursor="Hand">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
              </Grid.ColumnDefinitions>

              <!-- Type icon badge -->
              <Border Grid.Column="0" x:Name="IconBadge"
                      Width="42" Height="42" CornerRadius="8"
                      Background="{DynamicResource BadgeConnectedBrush}"
                      Margin="0,0,12,0" VerticalAlignment="Center">
                <ui:SymbolIcon x:Name="TypeIcon"
                               Symbol="{Binding AdapterType, Converter={StaticResource AdapterTypeToSymbol}}"
                               FontSize="22"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
              </Border>

              <!-- Info -->
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,4,0">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding Name}"
                             FontWeight="SemiBold" FontSize="13"
                             FontFamily="Segoe UI"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextBrush}"/>
                  <ui:Button x:Name="CopyBtn"
                             Appearance="Transparent"
                             Margin="6,0,0,0"
                             Tag="{Binding CurrentIp}"
                             Click="CopyIp_Click"
                             ToolTip="{DynamicResource Adapters.CopyIpTooltip}"
                             VerticalAlignment="Center"
                             Padding="3,2"
                             Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="Copy20" FontSize="11"/>
                  </ui:Button>
                </StackPanel>

                <TextBlock x:Name="IpLabel"
                           Text="{Binding CurrentIp}"
                           Foreground="{DynamicResource SubtextBrush}"
                           FontSize="12" FontFamily="Segoe UI"
                           Margin="0,2,0,0"/>

                <TextBlock Text="{Binding Description}"
                           FontSize="10" FontFamily="Segoe UI"
                           Foreground="{DynamicResource MutedBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,1,0,0"/>
                <TextBlock Text="{Binding CurrentDnsDisplay}"
                           FontSize="10" FontFamily="Consolas"
                           Foreground="{DynamicResource MutedBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,1,0,0">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Visibility" Value="Visible"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentDnsDisplay}" Value="">
                          <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </StackPanel>

              <!-- Status column: dot always centered, DHCP badge pinned to bottom -->
              <Grid Grid.Column="2">
                <Ellipse x:Name="PulseRing" Width="14" Height="14" Opacity="0"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Ellipse.Fill>
                    <SolidColorBrush Color="{StaticResource StatusConnectedColor}"/>
                  </Ellipse.Fill>
                </Ellipse>
                <Ellipse x:Name="StatusDot" Width="9" Height="9"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Fill="{Binding IsConnected, Converter={StaticResource StatusToColor}}"/>

                <Border x:Name="DhcpBadge"
                        CornerRadius="4" Padding="5,2"
                        Background="{DynamicResource DhcpBadgeBrush}"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,2">
                  <TextBlock Text="DHCP" FontSize="9" FontWeight="SemiBold"
                             FontFamily="Segoe UI"
                             Foreground="{DynamicResource SuccessBrush}"/>
                </Border>
              </Grid>
            </Grid>
          </Border>

          <DataTemplate.Triggers>

            <!-- Selected: accent border + themed background -->
            <DataTrigger Binding="{Binding IsSelected,
                         RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                         Value="True">
              <Setter TargetName="CardBorder" Property="BorderBrush"
                      Value="{DynamicResource AccentBrush}"/>
              <Setter TargetName="CardBorder" Property="Background"
                      Value="{DynamicResource CardSelectedBrush}"/>
            </DataTrigger>

            <!-- Connected: gentle slow opacity pulse -->
            <DataTrigger Binding="{Binding IsConnected}" Value="True">
              <DataTrigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="PulseRing"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.55" To="0"
                                     Duration="0:0:1.8"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.EnterActions>
              <DataTrigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PulseRing"
                                     Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.3"/>
                  </Storyboard>
                </BeginStoryboard>
              </DataTrigger.ExitActions>
            </DataTrigger>

            <!-- Disconnected: red badge, high-contrast icon, red label -->
            <DataTrigger Binding="{Binding IsConnected}" Value="False">
              <Setter TargetName="IconBadge" Property="Background"
                      Value="{DynamicResource BadgeDisconnectedBrush}"/>
              <Setter TargetName="TypeIcon"  Property="Foreground"
                      Value="{DynamicResource BadgeDisconnectedIconBrush}"/>
              <Setter TargetName="IpLabel"   Property="Text"       Value="{DynamicResource Adapters.NotConnected}"/>
              <Setter TargetName="IpLabel"   Property="Foreground"
                      Value="{DynamicResource DangerBrush}"/>
            </DataTrigger>

            <!-- DHCP badge -->
            <DataTrigger Binding="{Binding IsDhcp}" Value="True">
              <Setter TargetName="DhcpBadge" Property="Visibility" Value="Visible"/>
            </DataTrigger>

          </DataTemplate.Triggers>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</UserControl>
