<ui:FluentWindow x:Class="NetworkProfileManager.Views.PingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="{DynamicResource Ping.Title}"
        Width="500" Height="500"
        MinWidth="380" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- TitleBar -->
    <ui:TitleBar Grid.Row="0"
                 Background="{DynamicResource TitleBarBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 ShowMaximize="False"
                 ShowMinimize="False">
      <ui:TitleBar.Header>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
          <ui:SymbolIcon Symbol="NetworkCheck20" FontSize="14"
                         Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
          <TextBlock Foreground="{DynamicResource SubtextBrush}" FontSize="12">
            <Run Text="{DynamicResource Ping.Title}"/><Run Text=" — "/>
          </TextBlock>
          <TextBlock x:Name="TitleHost" Foreground="{DynamicResource AccentBrush}"
                     FontSize="12" FontWeight="SemiBold"/>
        </StackPanel>
      </ui:TitleBar.Header>
    </ui:TitleBar>

    <!-- Status bar -->
    <Border Grid.Row="1"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="14,8">
      <StackPanel Orientation="Horizontal">
        <Ellipse x:Name="StatusDot" Width="8" Height="8"
                 Fill="{DynamicResource SubtextBrush}"
                 VerticalAlignment="Center" Margin="0,0,8,0"/>
        <TextBlock x:Name="StatusText" Text="{DynamicResource Common.Ready}"
                   Foreground="{DynamicResource SubtextBrush}"
                   FontSize="12" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- Results -->
    <ScrollViewer Grid.Row="2" x:Name="ResultScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="14,8">
      <StackPanel x:Name="ResultStack"/>
    </ScrollViewer>

    <!-- Summary -->
    <Border Grid.Row="3" x:Name="SummaryBorder"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="14,8"
            Visibility="Collapsed">
      <TextBlock x:Name="SummaryText"
                 Foreground="{DynamicResource SubtextBrush}"
                 FontSize="11"/>
    </Border>

    <!-- Buttons -->
    <Border Grid.Row="4" Background="{DynamicResource TitleBarBrush}" Padding="14,8">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <ui:Button x:Name="RetryBtn"
                   Appearance="Secondary"
                   Padding="12,6" Margin="0,0,8,0"
                   Click="RetryClick">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="ArrowSync20" FontSize="13" Margin="0,0,6,0"/>
            <TextBlock Text="{DynamicResource Common.Retry}"/>
          </StackPanel>
        </ui:Button>
        <ui:Button Content="{DynamicResource Common.Close}"
                   Appearance="Primary"
                   Padding="14,6" Click="CloseClick"/>
      </StackPanel>
    </Border>
  </Grid>
</ui:FluentWindow>
