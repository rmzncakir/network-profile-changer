<ui:FluentWindow x:Class="NetworkProfileManager.Views.IpScannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:NetworkProfileManager.ViewModels"
        Title="{DynamicResource Scanner.Title}"
        Width="900" Height="600"
        MinWidth="680" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0"
                 Title="{DynamicResource Scanner.Title}"
                 Background="{DynamicResource TitleBarBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 ShowMaximize="False" ShowMinimize="False">
      <ui:TitleBar.Header>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
          <ui:SymbolIcon Symbol="NetworkCheck20" FontSize="14"
                         Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
          <TextBlock Text="{DynamicResource Scanner.Title}" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextBrush}"/>
        </StackPanel>
      </ui:TitleBar.Header>
    </ui:TitleBar>

    <!-- Toolbar -->
    <Border Grid.Row="1"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="14,10">
      <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
        <ui:TextBox Width="165" PlaceholderText="{DynamicResource Scanner.StartIp}"
                    Margin="0,0,10,4"
                    Text="{Binding StartIp, UpdateSourceTrigger=PropertyChanged}"
                    IsEnabled="{Binding IsNotScanning}"
                    Icon="{ui:SymbolIcon ArrowCircleRight20}"/>
        <ui:TextBox Width="165" PlaceholderText="{DynamicResource Scanner.EndIp}"
                    Margin="0,0,10,4"
                    Text="{Binding EndIp, UpdateSourceTrigger=PropertyChanged}"
                    IsEnabled="{Binding IsNotScanning}"
                    Icon="{ui:SymbolIcon ArrowCircleLeft20}"/>
        <ui:NumberBox Width="130" Margin="0,0,10,4"
                      PlaceholderText="{DynamicResource Scanner.TimeoutMs}"
                      Value="{Binding TimeoutMs, Mode=TwoWay}"
                      Minimum="100" Maximum="10000" SmallChange="100"
                      SpinButtonPlacementMode="Inline"
                      IsEnabled="{Binding IsNotScanning}"/>
        <ui:NumberBox Width="110" Margin="0,0,14,4"
                      PlaceholderText="{DynamicResource Scanner.MaxParallel}"
                      Value="{Binding MaxParallel, Mode=TwoWay}"
                      Minimum="1" Maximum="200" SmallChange="10"
                      SpinButtonPlacementMode="Inline"
                      IsEnabled="{Binding IsNotScanning}"/>
        <ui:Button Appearance="Primary" Margin="0,0,6,4"
                   Command="{Binding StartCommand}">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Play20" FontSize="13" Margin="0,0,6,0"/>
            <TextBlock Text="{DynamicResource Scanner.StartButton}"/>
          </StackPanel>
        </ui:Button>
        <ui:Button Appearance="Danger" Margin="0,0,0,4"
                   Command="{Binding StopCommand}">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Stop20" FontSize="13" Margin="0,0,6,0"/>
            <TextBlock Text="{DynamicResource Scanner.StopButton}"/>
          </StackPanel>
        </ui:Button>
      </WrapPanel>
    </Border>

    <!-- Progress -->
    <Border Grid.Row="2"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="14,8"
            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
      <StackPanel>
        <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Maximum="100"
                     Height="4" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding StatusText}"
                   Foreground="{DynamicResource SubtextBrush}"
                   FontSize="11" FontFamily="Segoe UI"/>
      </StackPanel>
    </Border>

    <!-- Results DataGrid -->
    <DataGrid Grid.Row="3"
              ItemsSource="{Binding Results}"
              SelectedItem="{Binding SelectedResult}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              SelectionMode="Single"
              HeadersVisibility="Column"
              VerticalScrollBarVisibility="Auto"
              Background="{DynamicResource BackgroundBrush}"
              BorderThickness="0"
              Foreground="{DynamicResource TextBrush}"
              RowBackground="{DynamicResource BackgroundBrush}"
              AlternatingRowBackground="{DynamicResource AlternatingRowBrush}"
              GridLinesVisibility="Horizontal"
              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
              RowHeight="36"
              FontFamily="Segoe UI"
              FontSize="12">

      <DataGrid.ColumnHeaderStyle>
        <Style TargetType="DataGridColumnHeader">
          <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
          <Setter Property="Foreground"      Value="{DynamicResource SubtextBrush}"/>
          <Setter Property="Padding"         Value="12,7"/>
          <Setter Property="FontWeight"      Value="SemiBold"/>
          <Setter Property="FontSize"        Value="11"/>
          <Setter Property="BorderThickness" Value="0,0,0,1"/>
          <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
          <Setter Property="FontFamily"      Value="Segoe UI"/>
        </Style>
      </DataGrid.ColumnHeaderStyle>

      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
          <Setter Property="Background"               Value="Transparent"/>
          <Setter Property="Foreground"               Value="{DynamicResource TextBrush}"/>
          <Setter Property="VerticalContentAlignment" Value="Center"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsOnline}" Value="False">
              <Setter Property="Opacity" Value="0.4"/>
            </DataTrigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{DynamicResource RowSelectedBrush}"/>
            </Trigger>
          </Style.Triggers>
        </Style>
      </DataGrid.RowStyle>

      <DataGrid.CellStyle>
        <Style TargetType="DataGridCell">
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="DataGridCell">
                <Border Background="{TemplateBinding Background}" Padding="12,0">
                  <ContentPresenter VerticalAlignment="Center"/>
                </Border>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{DynamicResource RowSelectedBrush}"/>
            </Trigger>
          </Style.Triggers>
        </Style>
      </DataGrid.CellStyle>

      <DataGrid.Columns>
        <!-- IP column with inline copy button -->
        <DataGridTemplateColumn Header="{DynamicResource Scanner.ColumnIp}" Width="170" SortMemberPath="IpAddress">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding IpAddress}"
                           FontFamily="Consolas" FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
                <ui:Button x:Name="CopyIpBtn"
                           Appearance="Transparent"
                           Padding="4,2" Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           ToolTip="{DynamicResource Adapters.CopyIpTooltip}"
                           Tag="{Binding IpAddress}"
                           Click="CopyIp_Click">
                  <ui:SymbolIcon Symbol="Copy20" FontSize="11"/>
                </ui:Button>
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="{DynamicResource Scanner.ColumnStatus}"       Binding="{Binding IsOnline, Converter={StaticResource BoolToStr}, ConverterParameter='✓ Online|— Offline'}" Width="95"/>
        <DataGridTextColumn Header="{DynamicResource Scanner.ColumnResponseTime}"  Binding="{Binding ResponseTime}" Width="85"/>
        <DataGridTextColumn Header="{DynamicResource Scanner.ColumnHostname}"      Binding="{Binding HostName}"     Width="*"/>
        <DataGridTextColumn Header="{DynamicResource Scanner.ColumnMac}"           Binding="{Binding MacAddress}"   Width="150" FontFamily="Consolas" FontSize="11"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Bottom bar -->
    <Border Grid.Row="4"
            Background="{DynamicResource TitleBarBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="14,8">
      <DockPanel>
        <TextBlock DockPanel.Dock="Left"
                   Text="{Binding StatusText}"
                   Foreground="{DynamicResource SubtextBrush}"
                   FontSize="11" FontFamily="Segoe UI"
                   VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
          <ui:Button Appearance="Secondary" Padding="12,5" Margin="0,0,6,0"
                     Click="CopySelected_Click">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Copy20" FontSize="13" Margin="0,0,5,0"/>
              <TextBlock Text="{DynamicResource Common.Copy}"/>
            </StackPanel>
          </ui:Button>
          <ui:Button Appearance="Secondary" Padding="12,5" Margin="0,0,6,0"
                     Command="{Binding ExportCommand}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="ArrowExportLtr20" FontSize="13" Margin="0,0,5,0"/>
              <TextBlock Text="CSV"/>
            </StackPanel>
          </ui:Button>
          <ui:Button Appearance="Primary" Padding="14,5"
                     Command="{Binding ApplyIpCommand}"
                     CommandParameter="{Binding SelectedResult}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="ArrowRight20" FontSize="13" Margin="0,0,5,0"/>
              <TextBlock Text="{DynamicResource Scanner.ApplyIp}"/>
            </StackPanel>
          </ui:Button>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</ui:FluentWindow>
