<UserControl x:Class="NetworkProfileManager.Views.ProfilePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

  <DockPanel>
    <!-- Header -->
    <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderBorder}">
      <DockPanel>
        <TextBlock Style="{StaticResource HeaderText}">
          <Run Text="{DynamicResource Profiles.Header}"/>
          <Run Text=" — "/>
          <Run Text="{Binding SelectedAdapter.Name, FallbackValue='', Mode=OneWay}"/>
        </TextBlock>
        <ui:Button DockPanel.Dock="Right"
                   HorizontalAlignment="Right"
                   Appearance="Secondary" Padding="8,5"
                   Click="AddProfile_Click">
          <ui:Button.Style>
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedAdapter.Profiles.Count}" Value="5">
                  <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding SelectedAdapter}" Value="{x:Null}">
                  <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ui:Button.Style>
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Add20" FontSize="13" Margin="0,0,6,0"/>
            <TextBlock Text="{DynamicResource Profiles.AddButton}" FontSize="12"/>
          </StackPanel>
        </ui:Button>
      </DockPanel>
    </Border>

    <!-- Content area -->
    <Grid Background="{DynamicResource BackgroundBrush}">
      <!-- Empty / no-adapter hint -->
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding SelectedAdapter}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding SelectedAdapter.Profiles.Count}" Value="0">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>
        <ui:SymbolIcon Symbol="DesktopFlow24" FontSize="32"
                       Foreground="{DynamicResource MutedBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Foreground="{DynamicResource SubtextBrush}"
                   FontSize="12" TextAlignment="Center">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Text" Value="{DynamicResource Profiles.NoProfiles}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedAdapter}" Value="{x:Null}">
                  <Setter Property="Text" Value="{DynamicResource Profiles.NoAdapterSelected}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </StackPanel>

      <!-- Profile cards -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ItemsControl ItemsSource="{Binding SelectedAdapter.Profiles}" Margin="8,6">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <!-- Outer border: accent highlight when IsActive -->
              <Border x:Name="CardOuter" Margin="4" Width="200" CornerRadius="8">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="BorderThickness" Value="1.5"/>
                    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                    <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BorderThickness"  Value="2"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <!-- Card header — top corners match the outer border's radius -->
                  <Border Grid.Row="0"
                          Background="{DynamicResource SurfaceBrush}"
                          CornerRadius="6,6,0,0"
                          Padding="10,8">
                    <DockPanel>
                      <!-- "Aktif" chip — visible only when IsActive -->
                      <Border DockPanel.Dock="Right" CornerRadius="4" Padding="5,1"
                              Background="{DynamicResource AccentBrush}"
                              VerticalAlignment="Center" Margin="4,0,0,0">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{DynamicResource Profiles.Active}" FontSize="9" FontWeight="SemiBold"
                                   Foreground="White"/>
                      </Border>
                      <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DatabasePlugConnected20" FontSize="14"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="SemiBold" FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </DockPanel>
                  </Border>

                  <!-- IP info -->
                  <StackPanel Grid.Row="1" Margin="10,8">
                    <Grid Margin="0,1">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="IP" Grid.Column="0"
                                 Foreground="{DynamicResource SubtextBrush}" FontSize="11"/>
                      <TextBlock Grid.Column="1" Text="{Binding IpDisplay}"
                                 FontSize="11" FontFamily="Consolas"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Grid Margin="0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Subnet" Grid.Column="0"
                                 Foreground="{DynamicResource SubtextBrush}" FontSize="11"/>
                      <TextBlock Grid.Column="1" Text="{Binding SubnetDisplay}"
                                 FontSize="11" FontFamily="Consolas"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Grid Margin="0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="GW" Grid.Column="0"
                                 Foreground="{DynamicResource SubtextBrush}" FontSize="11"/>
                      <TextBlock Grid.Column="1" Text="{Binding GatewayDisplay}"
                                 FontSize="11" FontFamily="Consolas"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                    <Grid Margin="0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="DNS" Grid.Column="0"
                                 Foreground="{DynamicResource SubtextBrush}" FontSize="11"/>
                      <TextBlock Grid.Column="1" Text="{Binding DnsDisplay}"
                                 FontSize="11" FontFamily="Consolas"
                                 TextTrimming="CharacterEllipsis"/>
                    </Grid>
                  </StackPanel>

                  <!-- Action buttons -->
                  <Grid Grid.Row="2" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="4"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="4"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:Button Grid.Column="0"
                               Content="{DynamicResource Common.Apply}"
                               Appearance="Primary"
                               FontSize="12" Padding="8,7"
                               Command="{Binding DataContext.ApplyProfileCommand,
                                         RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                               CommandParameter="{Binding}"/>
                    <ui:Button Grid.Column="2"
                               Appearance="Secondary"
                               FontSize="11" Padding="8,6"
                               Tag="{Binding}"
                               Click="EditProfile_Click"
                               ToolTip="{DynamicResource Profiles.EditTooltip}">
                      <ui:SymbolIcon Symbol="Edit20" FontSize="13"/>
                    </ui:Button>
                    <ui:Button Grid.Column="4"
                               Appearance="Danger"
                               FontSize="11" Padding="8,6"
                               Command="{Binding DataContext.DeleteProfileCommand,
                                         RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                               CommandParameter="{Binding}">
                      <ui:SymbolIcon Symbol="Delete20" FontSize="13"/>
                    </ui:Button>
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</UserControl>
