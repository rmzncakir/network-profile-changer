<ui:FluentWindow x:Class="NetworkProfileManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:NetworkProfileManager.ViewModels"
        xmlns:views="clr-namespace:NetworkProfileManager.Views"
        Title="{DynamicResource App.Title}"
        Icon="Assets/icon.ico"
        Width="960" Height="660"
        MinWidth="720" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

  <ui:FluentWindow.DataContext>
    <vm:MainViewModel/>
  </ui:FluentWindow.DataContext>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- ═══ Row 0: TitleBar ═══ -->
    <ui:TitleBar Grid.Row="0"
                 Title="{DynamicResource App.Title}"
                 Background="{DynamicResource TitleBarBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 ShowMaximize="True"
                 ShowMinimize="True">
      <ui:TitleBar.Header>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
          <TextBlock Text="⬡" Foreground="{DynamicResource AccentBrush}"
                     FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
          <TextBlock Text="{DynamicResource App.Title}"
                     Foreground="{DynamicResource TextBrush}"
                     FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
        </StackPanel>
      </ui:TitleBar.Header>
      <!-- TrailingContent = right side before window buttons, always hit-testable -->
      <ui:TitleBar.TrailingContent>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
          <ui:Button Appearance="Transparent" Padding="10,6" Margin="0,0,2,0"
                     FontSize="11" Click="OpenScannerClick"
                     ToolTip="{DynamicResource MainWindow.IpScannerTooltip}">
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="SearchInfo20" FontSize="13" Margin="0,0,6,0"/>
              <TextBlock Text="{DynamicResource MainWindow.IpScannerButton}" VerticalAlignment="Center"/>
            </StackPanel>
          </ui:Button>
          <ui:Button Appearance="Transparent" Padding="8,6"
                     ToolTip="{DynamicResource MainWindow.SettingsTooltip}" Click="OpenThemeClick">
            <ui:SymbolIcon Symbol="Settings20" FontSize="14"/>
          </ui:Button>
        </StackPanel>
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <!-- ═══ Row 1: Main panels ═══ -->
    <Grid Grid.Row="1" x:Name="MainContent"
          Background="{DynamicResource BackgroundBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="290" MinWidth="200"/>
        <ColumnDefinition Width="6"/>
        <ColumnDefinition Width="*" MinWidth="240"/>
      </Grid.ColumnDefinitions>

      <!-- Left: Adapter list -->
      <Border Grid.Column="0"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,1,0">
        <views:AdapterListPanel/>
      </Border>

      <!-- Modern splitter -->
      <GridSplitter Grid.Column="1" Width="6"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    Cursor="SizeWE" ShowsPreview="False">
        <GridSplitter.Template>
          <ControlTemplate TargetType="GridSplitter">
            <Border Background="Transparent">
              <Rectangle Width="1" Fill="{DynamicResource BorderBrush}" HorizontalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </GridSplitter.Template>
      </GridSplitter>

      <!-- Right: Profile + History -->
      <DockPanel Grid.Column="2" x:Name="RightPanel"
                 Background="{DynamicResource BackgroundBrush}">
        <Border DockPanel.Dock="Top" Height="280"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
          <views:ProfilePanel/>
        </Border>
        <views:HistoryPanel/>
      </DockPanel>
    </Grid>

    <!-- ═══ Row 2: IP Edit bar ═══ -->
    <Border Grid.Row="2"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="1"/>
          <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- IP Form -->
        <StackPanel Grid.Column="0"
                    IsEnabled="{Binding SelectedAdapter, Converter={StaticResource NullToBool}}">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <RadioButton Content="{DynamicResource EditBar.Dhcp}"
                         IsChecked="{Binding SelectedAdapter.EditIsDhcp, FallbackValue=False}"
                         Margin="0,0,20,0"/>
            <RadioButton Content="{DynamicResource EditBar.Static}"
                         IsChecked="{Binding SelectedAdapter.EditIsStatic, FallbackValue=True}"/>
          </StackPanel>
          <WrapPanel Orientation="Horizontal">
            <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
              <ui:TextBox Width="148" PlaceholderText="{DynamicResource EditBar.Ip}"
                          Text="{Binding SelectedAdapter.EditIp, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                          IsEnabled="{Binding SelectedAdapter.EditIsStatic, FallbackValue=False}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
              <ui:TextBox Width="148" PlaceholderText="{DynamicResource EditBar.Subnet}"
                          Text="{Binding SelectedAdapter.EditSubnet, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                          IsEnabled="{Binding SelectedAdapter.EditIsStatic, FallbackValue=False}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
              <ui:TextBox Width="148" PlaceholderText="{DynamicResource EditBar.Gateway}"
                          Text="{Binding SelectedAdapter.EditGateway, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                          IsEnabled="{Binding SelectedAdapter.EditIsStatic, FallbackValue=False}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,10,4">
              <ui:TextBox Width="148" PlaceholderText="{DynamicResource EditBar.PrimaryDns}"
                          Text="{Binding SelectedAdapter.EditPrimaryDns, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding SelectedAdapter.EditIsStatic, FallbackValue=False}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,12,4">
              <ui:TextBox Width="148" PlaceholderText="{DynamicResource EditBar.SecondaryDns}"
                          Text="{Binding SelectedAdapter.EditSecondaryDns, UpdateSourceTrigger=PropertyChanged}"
                          IsEnabled="{Binding SelectedAdapter.EditIsStatic, FallbackValue=False}"/>
            </StackPanel>
            <ui:Button Content="{DynamicResource Common.Apply}"
                       Appearance="Primary"
                       Padding="18,7" FontSize="13"
                       VerticalAlignment="Bottom"
                       Command="{Binding ApplyCommand}"/>
          </WrapPanel>
        </StackPanel>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}" Margin="8,0"/>

        <!-- Ping section -->
        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
          <TextBlock Text="{DynamicResource EditBar.PingHeader}" Style="{StaticResource FieldLabel}"
                     FontWeight="SemiBold" Margin="0,0,0,6"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="4"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" PlaceholderText="{DynamicResource EditBar.PingPlaceholder}"
                        Text="{Binding SelectedAdapter.PingTarget, UpdateSourceTrigger=PropertyChanged, FallbackValue=''}"
                        IsEnabled="{Binding SelectedAdapter, Converter={StaticResource NullToBool}}"/>
            <ui:Button Grid.Column="2" Content="{DynamicResource EditBar.PingButton}"
                       Appearance="Secondary" Padding="10,5"
                       Command="{Binding PingCommand}"/>
            <ui:Button Grid.Column="4"
                       Appearance="Transparent" Padding="8,5"
                       ToolTip="{DynamicResource EditBar.PingWindowTooltip}"
                       Click="OpenPingWindowClick"
                       IsEnabled="{Binding SelectedAdapter, Converter={StaticResource NullToBool}}">
              <ui:SymbolIcon Symbol="FullScreenMaximize20" FontSize="14"/>
            </ui:Button>
          </Grid>

          <!-- Ping result badge -->
          <Border Margin="0,6,0,0"
                  Background="{DynamicResource BackgroundBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1" CornerRadius="4" Padding="8,5">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding SelectedAdapter.PingResult}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding SelectedAdapter.PingResult}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding SelectedAdapter}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0"
                       Fill="{Binding SelectedAdapter.PingSuccess, Converter={StaticResource StatusToColor}}"/>
              <TextBlock Text="{Binding SelectedAdapter.PingResult}"
                         FontSize="11" Foreground="{DynamicResource TextBrush}"
                         TextTrimming="CharacterEllipsis"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ Row 3: Status bar ═══ -->
    <Border Grid.Row="3" Background="{DynamicResource TitleBarBrush}" Padding="14,5">
      <DockPanel>
        <ui:ProgressRing DockPanel.Dock="Right"
                         Width="16" Height="16" Margin="0,0,8,0"
                         IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource SubtextBrush}"
                   FontSize="11" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"/>
      </DockPanel>
    </Border>

    <!-- Busy overlay -->
    <Grid Grid.Row="1" Grid.RowSpan="2"
          Background="#CC0D0D1A"
          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
      <Border Background="{DynamicResource SurfaceBrush}"
              CornerRadius="10" Padding="32,18"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Orientation="Horizontal">
          <ui:ProgressRing Width="22" Height="22" IsIndeterminate="True" Margin="0,0,12,0"/>
          <TextBlock Text="{DynamicResource MainWindow.BusyApplying}"
                     FontSize="14" Foreground="{DynamicResource TextBrush}"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- SnackbarPresenter -->
    <ui:SnackbarPresenter x:Name="RootSnackbar"
                          Grid.Row="0" Grid.RowSpan="4"
                          VerticalAlignment="Bottom"
                          Margin="16,0,16,12"/>

    <!-- ContentDialogHost -->
    <ui:ContentDialogHost x:Name="RootDialogHost"
                          Grid.Row="0" Grid.RowSpan="4"/>
  </Grid>
</ui:FluentWindow>
